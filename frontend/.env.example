# Backend API adresi. Claude anahtarı ARTIK istemcide DEĞİL — yalnızca backend'de tutulur.
#
# Emülatör/simülatör:   http://localhost:8080
# Fiziksel cihaz:        bilgisayarının yerel ağ IP'si, örn. http://192.168.1.20:8080
#   (IP'yi öğrenmek için Windows'ta `ipconfig`, macOS'ta `ipconfig getifaddr en0`)
EXPO_PUBLIC_API_URL=http://localhost:8080

# --- Google ile giriş (Google Cloud Console → Credentials) ---
# Boş bırakılırsa Google butonu gizlenir. Bu client id'ler backend'in
# falcim.oauth.google.client-ids listesiyle eşleşmelidir.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
