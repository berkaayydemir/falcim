# ─── Falcım Backend ortam değişkenleri ───
# Bu dosyayı `.env` olarak kopyalayın ve gerçek değerlerle doldurun.
# .env dosyasını ASLA versiyon kontrolüne eklemeyin.

# --- Veritabanı (docker-compose ile aynı olmalı) ---
DB_NAME=falcim
DB_USER=falcim
DB_PASSWORD=falcim_local_dev
DB_URL=jdbc:postgresql://localhost:5432/falcim

# --- JWT ---
# En az 32 baytlık (256-bit) rastgele bir gizli anahtar üretin, örn:
#   openssl rand -base64 48
JWT_SECRET=degistir-bu-en-az-32-karakterlik-guclu-bir-gizli-anahtar-olmali
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=14

# --- Claude / Anthropic ---
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6

# --- CORS (virgülle ayrılmış izinli origin'ler) ---
# Expo dev için genelde gerek yok; web istemcisi eklerseniz burayı doldurun.
CORS_ALLOWED_ORIGINS=http://localhost:19006,http://localhost:8081

# --- Aktif profil ---
SPRING_PROFILES_ACTIVE=dev
